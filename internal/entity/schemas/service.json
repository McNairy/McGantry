{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Service",
  "description": "Application, microservice, or backend component",
  "type": "object",
  "properties": {
    "type": {
      "type": "string",
      "enum": ["backend", "frontend", "fullstack", "library", "worker"],
      "description": "Service type"
    },
    "lifecycle": {
      "type": "string",
      "enum": ["experimental", "development", "production", "deprecated"],
      "description": "Lifecycle stage"
    },
    "system": {
      "type": "string",
      "description": "Parent system or domain"
    },
    "repoUrl": {
      "type": "string",
      "title": "Repository URL",
      "description": "Source repository URL (GitHub, GitLab, Bitbucket, etc.)"
    },
    "techDocsRef": {
      "type": "string",
      "title": "TechDocs Reference",
      "description": "Path or URL to this service's TechDocs (e.g., dir:., url:https://...)"
    },
    "apiDocsUrl": {
      "type": "string",
      "title": "API Docs URL",
      "description": "URL to Swagger UI, Redoc, or other API documentation page"
    },
    "healthCheckUrl": {
      "type": "string",
      "title": "Health Check URL",
      "description": "URL to the service health endpoint (e.g., https://api.example.com/healthz)"
    },
    "links": {
      "type": "array",
      "title": "Links",
      "description": "Useful links for this service (docs, dashboards, runbooks, etc.)",
      "items": {
        "type": "object",
        "properties": {
          "title": { "type": "string", "title": "Title", "description": "Display name for the link" },
          "url": { "type": "string", "title": "URL", "description": "Full URL" },
          "icon": {
            "type": "string",
            "title": "Icon",
            "description": "Icon hint for the link type",
            "enum": ["dashboard", "docs", "runbook", "github", "slack", "alert", "monitor", "ci", "other"]
          }
        },
        "required": ["title", "url"]
      }
    },
    "dependsOn": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "kind": { "type": "string" },
          "name": { "type": "string" }
        },
        "required": ["kind", "name"]
      },
      "description": "Entities this service depends on"
    },
    "providesApis": {
      "type": "array",
      "items": { "type": "string", "x-entity-ref": "API" },
      "description": "APIs provided by this service"
    },
    "consumesApis": {
      "type": "array",
      "items": { "type": "string", "x-entity-ref": "API" },
      "description": "APIs consumed by this service"
    },
    "deployedIn": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "kind": { "type": "string" },
          "name": { "type": "string" }
        },
        "required": ["kind", "name"]
      },
      "description": "Environments this service is deployed in"
    }
  },
  "additionalProperties": false
}
