{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Documentation",
  "description": "Link to external documentation or runbook",
  "type": "object",
  "properties": {
    "type": {
      "type": "string",
      "enum": ["runbook", "wiki", "api-docs", "architecture"],
      "description": "Documentation type"
    },
    "url": {
      "type": "string",
      "format": "uri",
      "description": "URL to the documentation resource"
    },
    "associatedEntity": {
      "type": "string",
      "description": "Legacy entity reference this documentation is associated with (for example, Service/checkout)",
      "x-hidden": true
    },
    "relatedTo": {
      "type": "array",
      "title": "Relates to",
      "items": {
        "type": "object",
        "properties": {
          "kind": { "type": "string" },
          "name": { "type": "string" }
        },
        "required": ["kind", "name"],
        "additionalProperties": false
      },
      "description": "Entities this documentation relates to"
    },
    "format": {
      "type": "string",
      "description": "Document format (e.g., markdown, html, pdf)"
    },
    "system": {
      "type": "string",
      "description": "Parent system or domain"
    }
  },
  "required": ["url"],
  "additionalProperties": false
}
