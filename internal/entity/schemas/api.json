{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "API",
  "description": "REST, gRPC, GraphQL, or event-based API definition",
  "type": "object",
  "properties": {
    "type": {
      "type": "string",
      "enum": ["rest", "grpc", "graphql", "event"],
      "description": "API type"
    },
    "lifecycle": {
      "type": "string",
      "enum": ["experimental", "development", "production", "deprecated"],
      "description": "Lifecycle stage"
    },
    "definition": {
      "type": "string",
      "format": "uri",
      "description": "URL to the API definition document (e.g., OpenAPI spec)"
    },
    "apiDocsUrl": {
      "type": "string",
      "title": "API Docs URL",
      "description": "URL to Swagger UI, Redoc, or other API documentation page"
    },
    "healthCheckUrl": {
      "type": "string",
      "title": "Health Check URL",
      "description": "URL to the API health endpoint (e.g., https://api.example.com/healthz)"
    },
    "owner": {
      "type": "string",
      "description": "Team or individual that owns this API"
    },
    "system": {
      "type": "string",
      "description": "Parent system or domain"
    },
    "repoUrl": {
      "type": "string",
      "title": "Repository URL",
      "description": "Source repository URL (GitHub, GitLab, Bitbucket, etc.)"
    },
    "links": {
      "type": "array",
      "title": "Links",
      "description": "Useful links for this API (docs, spec, changelog, etc.)",
      "items": {
        "type": "object",
        "properties": {
          "title": { "type": "string", "title": "Title", "description": "Display name for the link" },
          "url": { "type": "string", "title": "URL", "description": "Full URL" },
          "icon": {
            "type": "string",
            "title": "Icon",
            "description": "Icon hint for the link type",
            "enum": ["dashboard", "docs", "runbook", "github", "slack", "alert", "monitor", "ci", "other"]
          }
        },
        "required": ["title", "url"]
      }
    },
    "dependsOn": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "kind": { "type": "string" },
          "name": { "type": "string" }
        },
        "required": ["kind", "name"]
      },
      "description": "Entities this API depends on"
    },
    "providesApis": {
      "type": "array",
      "items": { "type": "string", "x-entity-ref": "API" },
      "description": "APIs provided by this entity"
    },
    "consumesApis": {
      "type": "array",
      "items": { "type": "string", "x-entity-ref": "API" },
      "description": "APIs consumed by this entity"
    },
    "deployedIn": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "kind": { "type": "string" },
          "name": { "type": "string" }
        },
        "required": ["kind", "name"]
      },
      "description": "Environments this API is deployed in"
    }
  },
  "additionalProperties": false
}
