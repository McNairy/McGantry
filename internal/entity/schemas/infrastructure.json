{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Infrastructure",
  "description": "Database, queue, cache, storage, or other infrastructure",
  "type": "object",
  "properties": {
    "type": {
      "type": "string",
      "enum": ["database", "queue", "cache", "storage", "bucket"],
      "description": "Infrastructure type"
    },
    "provider": {
      "type": "string",
      "description": "Cloud or infrastructure provider (e.g., AWS, GCP, Azure)"
    },
    "lifecycle": {
      "type": "string",
      "enum": ["experimental", "development", "production", "deprecated"],
      "description": "Lifecycle stage"
    },
    "connectionString": {
      "type": "string",
      "description": "Connection string or endpoint for the infrastructure resource"
    },
    "system": {
      "type": "string",
      "description": "Parent system or domain"
    },
    "repoUrl": {
      "type": "string",
      "title": "IaC Repository URL",
      "description": "Infrastructure-as-Code repository URL (Terraform, Pulumi, etc.)"
    },
    "links": {
      "type": "array",
      "title": "Links",
      "description": "Useful links for this resource (console, docs, runbooks, etc.)",
      "items": {
        "type": "object",
        "properties": {
          "title": { "type": "string", "title": "Title", "description": "Display name for the link" },
          "url": { "type": "string", "title": "URL", "description": "Full URL" },
          "icon": {
            "type": "string",
            "title": "Icon",
            "description": "Icon hint for the link type",
            "enum": ["dashboard", "docs", "runbook", "github", "slack", "alert", "monitor", "ci", "other"]
          }
        },
        "required": ["title", "url"]
      }
    },
    "dependsOn": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "kind": { "type": "string" },
          "name": { "type": "string" }
        },
        "required": ["kind", "name"]
      },
      "description": "Entities this resource depends on"
    },
    "providesApis": {
      "type": "array",
      "items": { "type": "string", "x-entity-ref": "API" },
      "description": "APIs provided by this entity"
    },
    "consumesApis": {
      "type": "array",
      "items": { "type": "string", "x-entity-ref": "API" },
      "description": "APIs consumed by this entity"
    },
    "deployedIn": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "kind": { "type": "string" },
          "name": { "type": "string" }
        },
        "required": ["kind", "name"]
      },
      "description": "Environments this resource is deployed in"
    }
  },
  "additionalProperties": false
}
