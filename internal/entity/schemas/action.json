{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Action",
  "description": "Self-service workflow definition",
  "type": "object",
  "properties": {
    "type": {
      "type": "string",
      "enum": ["github-action", "argocd-sync", "flux-update", "webhook", "internal"],
      "description": "Action execution type"
    },
    "category": {
      "type": "string",
      "description": "Grouping category shown as a section header on the Actions page (e.g. Deployment, Database, Security)"
    },
    "config": {
      "type": "object",
      "description": "Action-specific configuration (type-dependent fields)",
      "additionalProperties": true
    },
    "inputs": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Input parameter name (used as variable key)"
          },
          "title": {
            "type": "string",
            "description": "Human-readable label for the input"
          },
          "type": {
            "type": "string",
            "enum": ["string", "textarea", "number", "boolean", "select"],
            "description": "Input parameter type"
          },
          "description": {
            "type": "string",
            "description": "Help text shown below the input field"
          },
          "required": {
            "type": "boolean",
            "description": "Whether this input must be provided before execution"
          },
          "default": {
            "description": "Default value pre-filled in the form"
          },
          "options": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Available options for select-type inputs"
          }
        },
        "required": ["name", "type"]
      },
      "description": "Input parameters collected from the user before execution"
    },
    "permissions": {
      "type": "object",
      "properties": {
        "allowedRoles": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Roles allowed to execute this action"
        },
        "allowedTeams": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Teams allowed to execute this action"
        },
        "requireApproval": {
          "type": "boolean",
          "description": "Whether execution requires approval"
        },
        "approvers": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Users or teams that can approve execution"
        }
      },
      "additionalProperties": false,
      "description": "Access control for this action"
    }
  },
  "additionalProperties": false
}
